{
  "kind": "collectionType",
  "collectionName": "doctors",
  "info": {
    "singularName": "doctor",
    "pluralName": "doctors",
    "displayName": "Doctor"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "short_description": {
      "type": "string"
    },
    "full_description": {
      "type": "text"
    },
    "specialization": {
      "type": "string"
    },
    "featured": {
      "type": "boolean"
    },
    "experience_years": {
      "type": "integer"
    },
    "specialty": {
      "type": "string"
    },
    "intro_title": {
      "type": "string"
    },
    "intro_subtitle": {
      "type": "text"
    },
    "experiences": {
      "type": "component",
      "component": "experience-item.experience-item",
      "repeatable": true,
      "required": false
    },
    "disorders": {
      "type": "component",
      "component": "disorder-item.disorders",
      "repeatable": true
    },
    "approaches": {
      "type": "component",
      "component": "approach-item.approaches",
      "repeatable": true
    },
    "completed_sessions": {
      "type": "integer"
    },
    "rating": {
      "type": "decimal"
    },
    "degree": {
      "type": "string"
    },
    "university": {
      "type": "string"
    },
    "certification": {
      "type": "string"
    },
    "session_price": {
      "type": "decimal"
    },
    "session_duration": {
      "type": "string"
    },
    "languages": {
      "type": "string"
    },
    "available_days": {
      "type": "string"
    },
    "working_hours": {
      "type": "string"
    },
    "nationality": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "ذكر",
        "أنثى"
      ]
    }
  }
}
